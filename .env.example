# Backend configuration. Copy to .env (or export in your shell) before running
# `npm run dev --workspace @todolist/backend` outside Docker.
#
# All values listed below are REQUIRED unless explicitly marked optional.
# `loadConfig(process.env)` refuses to start if any required value is missing.

# Listening port (1..65535).
PORT=3000

# Path to the SQLite file. For local dev pick a path you can write; in the
# Docker image `/data/todolist.db` is mounted from the named volume.
DATABASE_PATH=./todolist.db

# CORS origins. One value, or a comma-separated list. Use `*` for "any" only
# when you know what you're doing (acceptable for tests, never for production).
CORS_ORIGIN=http://localhost:5173

# Maximum allowed request body size in bytes. Optional; default 65536.
# MAX_BODY_BYTES=65536

# Pino log level. Optional; default "info".
# LOG_LEVEL=info

# Node environment marker, surfaced in startup logs. Optional; default "production".
# NODE_ENV=development
