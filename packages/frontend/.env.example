# Frontend build-time configuration. Copy to `packages/frontend/.env` (or set
# in the shell before `vite build`) only if you need to override defaults.
# See ADR-0017 for the FE → BE traffic story.

# API base URL the FE prepends to every request path. Defaults to "/api",
# which works for both `npm run dev` (Vite proxies /api → http://localhost:3000)
# and `docker compose up` (nginx in the FE container proxies /api/ → backend:3000).
# Override only when serving the FE outside the supported stacks.
# VITE_API_BASE_URL=/api

# Where Vite's dev server forwards /api requests to. Read at `vite dev` /
# `vite build` time only — does NOT end up in the bundle. Defaults to
# http://localhost:3000. Override when running the BE on another host or port
# (e.g. a remote dev backend, a non-default port, or inside a corporate VPN).
# VITE_DEV_PROXY_TARGET=http://localhost:3000

# Set to "true" to build the GitHub Pages demo: the bundle starts MSW on boot
# and serves all /api/* requests from in-memory mocks. Off by default; the
# regular dev/Docker builds never ship MSW. Used by `npm run build:demo`.
# VITE_DEMO_MODE=true
